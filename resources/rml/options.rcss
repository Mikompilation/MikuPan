    padding-right: 8dp;
    overflow: hidden;
}

#options-root .setting-title {
    overflow: hidden;
}

#options-root .setting-control {
    width: 150dp;
    overflow: hidden;
}

#options-root .wide-control {
    width: 150dp;
}

#options-root select,
#options-root input.text,
#options-root .stepper-control,
#options-root .choice-picker {
    width: 144dp;
    overflow: hidden;
}

#options-root select selectvalue {
    width: 120dp;
    padding: 0dp 18dp 0dp 0dp;
