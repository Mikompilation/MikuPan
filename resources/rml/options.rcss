/* Option 6: photographic ritual pass. Inert overlay marks and more severe
 * menu geometry push the screen away from a clean app surface.
 */
#options-root #window {
    overflow: hidden;
    background-color: #020101f4;
    border: 1dp #2a1715;
    border-top-color: #3a1f1b;
    border-bottom-color: #241311;
}

#options-root #side {
    background-color: #030202e6;
    border-right-color: #241313;
}

#options-root #content {
    background-color: #01010133;
}

#ritual-overlay {
    display: block;
    position: absolute;
    left: 0dp;
    top: 0dp;
    width: 536dp;
    height: 306dp;
    pointer-events: none;
}

#ritual-edge-top,
#ritual-edge-bottom,
#ritual-edge-left,
#ritual-edge-right,
.ritual-corner,
.ritual-scratch,
.ritual-speck {
    display: block;
    position: absolute;
    pointer-events: none;
}

#ritual-edge-top {
    left: 0dp;
    top: 0dp;
    width: 536dp;
    height: 7dp;
    background-color: #00000034;
    border: 0dp transparent;
    border-top: 2dp #3a1f1b;
}

#ritual-edge-bottom {
    left: 0dp;
    bottom: 0dp;
    width: 536dp;
    height: 8dp;
    background-color: #0000003c;
    border: 0dp transparent;
    border-bottom: 2dp #241311;
}

#ritual-edge-left {
    left: 0dp;
    top: 0dp;
    width: 6dp;
    height: 306dp;
    background-color: #00000030;
    border: 0dp transparent;
    border-left: 2dp #2a1715;
}

#ritual-edge-right {
    right: 0dp;
    top: 0dp;
    width: 6dp;
    height: 306dp;
    background-color: #0000003a;
    border: 0dp transparent;
    border-right: 2dp #2a1715;
}

.ritual-corner {
    width: 21dp;
    height: 21dp;
    border: 0dp transparent;
}

#ritual-corner-tl {
    left: 6dp;
    top: 6dp;
    border-left: 2dp #6f2a22;
    border-top: 2dp #6f2a22;
}

#ritual-corner-tr {
    right: 6dp;
    top: 6dp;
    border-right: 2dp #5b3027;
    border-top: 2dp #5b3027;
}

#ritual-corner-bl {
    left: 6dp;
    bottom: 6dp;
    border-left: 2dp #5b3027;
    border-bottom: 2dp #5b3027;
}

#ritual-corner-br {
    right: 6dp;
    bottom: 6dp;
    border-right: 2dp #6f2a22;
    border-bottom: 2dp #6f2a22;
}

#ritual-scratch-a {
    left: 21dp;
    top: 38dp;
    width: 16dp;
    height: 1dp;
    background-color: #f4dcc512;
}

#ritual-scratch-b {
    right: 27dp;
