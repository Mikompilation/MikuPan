#options-root.theme-sepia .stepper-control,
#options-root.theme-sepia .choice-picker,
#options-root.theme-sepia button,
#options-root.theme-sepia .controls-bind-value {
    background-color: #070302b8;
    border-bottom-color: #321b18;
}

#options-root.theme-sepia .choice-picker:hover,
#options-root.theme-sepia .choice-picker:focus,
#options-root.theme-sepia .choice-picker:focus-visible,
#options-root.theme-sepia .choice-picker.controller-focus,
#options-root.theme-sepia .stepper-control:hover,
#options-root.theme-sepia .stepper-control:focus,
#options-root.theme-sepia .stepper-control:focus-visible,
#options-root.theme-sepia .stepper-control.controller-focus,
#options-root.theme-sepia button:hover,
#options-root.theme-sepia button:focus,
#options-root.theme-sepia button:focus-visible,
#options-root.theme-sepia button.controller-focus {
    background-color: #170806d8;
    border-bottom-color: #b78a62;
}

#options-root.theme-sepia #choice-picker-card,
#options-root.theme-sepia #confirm-save-card,
#options-root.theme-sepia #resolution-confirm-card,
#options-root.theme-sepia #binding-capture-card {
    background-color: #070302fa;
    border-left-color: #6f442f;
    border-bottom-color: #321b18;
}

#options-root.theme-sepia #choice-picker-list {
    background-color: #040201e8;
    border-top-color: #281613;
    border-bottom-color: #281613;
}
